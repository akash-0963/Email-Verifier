PORT=5000
NODE_ENV=development

# ============ AWS SES Configuration (Recommended) ============
# For bounce tracking and delivery verification with real-time webhooks
MAIL_HOST=email-smtp.ap-south-1.amazonaws.com
MAIL_USER=your_aws_smtp_username
MAIL_PASS=my_aws_smtp_password
MAIL_SECURE=false
MAIL_PORT=587
AWS_REGION=region-of-your-ses
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
SES_FROM_EMAIL=verified-email@yourdomain.com

# ============ Gmail Configuration (Optional Fallback) ============
# Used if SES not available - for delivery verification
# Get App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password

# ============ Custom SMTP Configuration (Legacy/Alternative) ============
# Use this if you have your own mail server
MAIL_HOST=smtp.yourmailserver.com
MAIL_USER=your_mail_user
MAIL_PASS=your_mail_password
MAIL_PORT=587
MAIL_SECURE=false
MAIL_FROM_EMAIL=noreply@yourdomain.com